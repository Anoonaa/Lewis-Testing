{
  "name": "lewis-visual-pipelines",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:app": "npm --prefix Lewis run dev",
    "ci:smoke:delivery": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec cypress/e2e/03-day-3-network/delivery-quote.cy.js\"",
    "ci:smoke:checkout": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec cypress/e2e/03-day-3-network/checkout-chain.cy.js\"",
    "ci:regression:architecture": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec DO-NOT-OPEN/02-day-2-architecture/retail-architecture.cy.js\"",
    "ci:regression:network": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec cypress/e2e/03-day-3-network/retail-network.cy.js,DO-NOT-OPEN/examples-2/retail-network.cy.js\"",
    "ci:regression:practical": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec cypress/e2e/03-day-3-network/practical-assessment.cy.js\"",
    "ci:legacy:todo": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec cypress/e2e/1-getting-started/todo.cy.js\"",
    "ci:legacy:network": "start-server-and-test dev:app http://127.0.0.1:5174 \"cypress run --config-file cypress.config.js --spec DO-NOT-OPEN/examples-2/retail-network.cy.js\"",
    "ci:smoke": "npm run ci:smoke:delivery && npm run ci:smoke:checkout",
    "ci:regression": "npm run ci:regression:architecture && npm run ci:regression:network && npm run ci:regression:practical",
    "ci:legacy": "npm run ci:legacy:todo && npm run ci:legacy:network"
  },
  "devDependencies": {
    "cypress": "^15.16.0",
    "start-server-and-test": "^3.0.5"
  }
}